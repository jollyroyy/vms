#!/usr/bin/env node
/**
 * pre-commit hook ‚Äî TDD enforcement (goal.md ¬ß7 / /tdd-loop skill ¬ß36-39)
 *
 * Runs `npm run check` (tsc --noEmit + all active tests) on EVERY commit.
 * Blocks the commit if ANY check fails.
 *
 * Never bypass with --no-verify. If a legitimate case arises,
 * fix the failing test instead ‚Äî deleting/skipping is forbidden.
 */

import { spawnSync } from 'node:child_process';

const RED    = (s) => `\x1b[31m${s}\x1b[0m`;
const GREEN  = (s) => `\x1b[32m${s}\x1b[0m`;
const BOLD   = (s) => `\x1b[1m${s}\x1b[0m`;
const DIM    = (s) => `\x1b[2m${s}\x1b[0m`;

console.log(BOLD('\n‚ïî‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïó'));
console.log(BOLD(  '‚ïë    pre-commit: TDD gate ‚Äî running npm run check‚Ä¶    ‚ïë'));
console.log(BOLD(  '‚ïö‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïù\n'));

const result = spawnSync('npm run check', {
  stdio: 'inherit',
  shell: true,
  env: { ...process.env, FORCE_COLOR: '1' },
});

if (result.status !== 0) {
  console.error(RED(BOLD('\n  ‚úñ  TDD gate FAILED ‚Äî commit blocked.\n')));
  console.error(DIM('     Fix the failing tests, then commit again.'));
  console.error(DIM('     Never use --no-verify to bypass the TDD gate.\n'));
  process.exit(1);
}

console.log(GREEN(BOLD('\n  ‚úî  TDD gate passed ‚Äî commit allowed.\n')));
process.exit(0);
