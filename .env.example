# Copy this to .env and fill in your Supabase project values.
# Never commit .env — it is git-ignored (SEC-4).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used ONLY by scripts/seed.ts (server-side).
# NEVER put this in src/ or client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
