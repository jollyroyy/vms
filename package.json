{
  "name": "vms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Visitor & Material Gate Pass Management System — mall management office",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run tests/unit tests/security/routeProtection.test.ts",
    "verify": "node scripts/run-verify.js",
    "verify:goal": "node scripts/run-verify.js --goal",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:security": "vitest run tests/security",
    "test:e2e": "playwright test tests/e2e",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "date-fns": "^3.6.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.6.1",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
